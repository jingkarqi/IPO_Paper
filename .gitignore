# Python cache and local environments
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.venv/
venv/
env/

# Editor and OS noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.code-workspace

# Secrets and local config
.env
.env.*

# Research data generated or kept locally
data/raw/**
data/interim/**
data/processed/**
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Generated outputs
outputs/tables/**
outputs/figures/**
!outputs/tables/.gitkeep
!outputs/figures/.gitkeep

# LaTeX build artifacts
paper/build/
paper/*.aux
paper/*.bbl
paper/*.bcf
paper/*.blg
paper/*.fdb_latexmk
paper/*.fls
paper/*.log
paper/*.out
paper/*.pdf
paper/*.run.xml
paper/*.synctex.gz
paper/*.toc
paper/*.xdv

# Office temporary files
~$*.xlsx
~$*.docx
~$*.pptx
